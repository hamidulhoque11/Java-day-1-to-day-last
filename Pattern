import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter your perretn value:");
        int n=sc.nextInt();
        for(int i=n;i>=1;i--){
            System.out.println();
            for(int j=1;j<=i;j++){
                if(j%2==0){
                System.out.print("0");
            }
            else{
                System.out.print("1");
            }
            }
            }
            
        }
    }
    /*
    output-
    101
    10
    1
    */
