import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter Small letter:");
        char character=sc.next().charAt(0);
        for(char i='a';i<=character;i++){
            
            for(char j='a';j<=i;j++){
                System.out.print(i+" ");
            }
            System.out.println();
        }
    }
}
/*
output-
    a
    b b
    c c c
*/
